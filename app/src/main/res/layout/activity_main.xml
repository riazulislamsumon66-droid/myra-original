<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/myra_dark">

    <!-- Ambient background gradient -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_gradient_mesh"/>

    <!-- Active state red overlay -->
    <View
        android:id="@+id/redOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/myra_red"
        android:alpha="0"
        android:clickable="false"/>

    <!-- TOP BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical">

        <!-- Left: Battery + RAM -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/batteryText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="100%"
                android:textColor="@color/myra_red_soft"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:drawableStart="@drawable/ic_battery"
                android:drawablePadding="4dp"/>

            <TextView
                android:id="@+id/ramText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--MB"
                android:textColor="@color/myra_hint"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Center: MYRA Title -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:gravity="center"
            android:orientation="vertical">

            <!-- Stylized MYRA letters -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/myra_full"
                android:textColor="@color/myra_red"
                android:textSize="22sp"
                android:letterSpacing="0.35"
                android:fontFamily="sans-serif-black"
                android:shadowColor="@color/myra_red"
                android:shadowDx="0"
                android:shadowDy="0"
                android:shadowRadius="12"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_tagline"
                android:textColor="@color/myra_hint"
                android:textSize="8sp"
                android:letterSpacing="0.5"
                android:fontFamily="monospace"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Right: Time + Settings -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/timeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="@color/myra_red_soft"
                android:textSize="14sp"
                android:fontFamily="monospace"/>

            <ImageButton
                android:id="@+id/settingsBtn"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_settings"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/myra_hint"
                android:layout_marginTop="4dp"
                android:contentDescription="Settings"/>
        </LinearLayout>
    </LinearLayout>

    <!-- CENTER AREA: ORB + WAVEFORM + STATUS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Orb Animation -->
        <com.maya.assistant.ui.main.OrbAnimationView
            android:id="@+id/orbView"
            android:layout_width="280dp"
            android:layout_height="280dp"/>

        <!-- Waveform -->
        <com.maya.assistant.ui.main.WaveformView
            android:id="@+id/waveformView"
            android:layout_width="220dp"
            android:layout_height="44dp"
            android:layout_marginTop="12dp"/>

        <!-- Status Text -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/system_ready"
            android:textColor="@color/myra_red"
            android:textSize="11sp"
            android:layout_marginTop="12dp"
            android:fontFamily="monospace"
            android:letterSpacing="0.15"
            android:alpha="0.85"
            android:shadowColor="@color/myra_red"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="8"/>
    </LinearLayout>

    <!-- BOTTOM AREA: Chat + Mic -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="bottom"
        android:paddingBottom="36dp">

        <!-- Chat Recycler -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/chatRecycler"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:clipToPadding="false"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:fadeScrollbars="true"
            android:scrollbars="none"/>

        <!-- Mic Button with glow ring -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp">

            <!-- Glow ring -->
            <View
                android:id="@+id/micGlow"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_orb_glow"
                android:alpha="0.4"/>

            <ImageButton
                android:id="@+id/micButton"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_mic_off"
                android:background="@drawable/bg_mic_button"
                android:elevation="8dp"
                android:contentDescription="Mic"/>
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/long_press_stop"
            android:textColor="@color/myra_hint"
            android:textSize="10sp"
            android:layout_gravity="center"
            android:layout_marginTop="6dp"
            android:fontFamily="monospace"
            android:letterSpacing="0.1"/>
    </LinearLayout>

</FrameLayout>
