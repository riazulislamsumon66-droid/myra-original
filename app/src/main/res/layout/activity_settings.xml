<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050505"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingTop="48dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙️ SETTINGS"
            android:textColor="#FF1744"
            android:textSize="20sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.3"
            android:layout_marginBottom="24dp" />

        <!-- Gemini API Key Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#111"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔑 Gemini API Key"
                    android:textColor="#FF6D6D"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="10dp" />

                <EditText
                    android:id="@+id/apiKeyInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Enter your Gemini API key..."
                    android:textColor="#FFF"
                    android:textColorHint="#555"
                    android:background="@drawable/bg_input_field"
                    android:padding="12dp"
                    android:inputType="textPassword"
                    android:fontFamily="monospace"
                    android:textSize="13sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- TTS / Voice Settings Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#111"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🗣️ Voice &amp; TTS Settings"
                    android:textColor="#FF6D6D"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="14dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TTS API Key (ElevenLabs)"
                    android:textColor="#888"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/ttsApiKeyInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="ElevenLabs API Key..."
                    android:textColor="#FFF"
                    android:textColorHint="#555"
                    android:background="@drawable/bg_input_field"
                    android:padding="12dp"
                    android:inputType="textPassword"
                    android:fontFamily="monospace"
                    android:textSize="13sp"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Voice Engine"
                    android:textColor="#888"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp" />

                <RadioGroup
                    android:id="@+id/voiceTypeGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/radioSystem"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="System Default"
                        android:textColor="#CCC"
                        android:textSize="12sp"
                        android:buttonTint="#FF1744" />

                    <RadioButton
                        android:id="@+id/radioEleven"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="ElevenLabs"
                        android:textColor="#CCC"
                        android:textSize="12sp"
                        android:buttonTint="#FF1744" />
                </RadioGroup>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#222"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Natural Voice (Live Mode)"
                        android:textColor="#CCC"
                        android:textSize="13sp" />

                    <Switch
                        android:id="@+id/liveModeSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumbTint="#FF1744"
                        android:trackTint="#444" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- User Name Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#111"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👤 Your Name"
                    android:textColor="#FF6D6D"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="10dp" />

                <EditText
                    android:id="@+id/userNameInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Sir"
                    android:textColor="#FFF"
                    android:textColorHint="#555"
                    android:background="@drawable/bg_input_field"
                    android:padding="12dp"
                    android:textSize="14sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Prime Contact Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#1A0000"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="⭐ PRIME CONTACT"
                        android:textColor="#FF1744"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.1" />

                    <ImageButton
                        android:id="@+id/pickContactBtn"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_contact_list"
                        android:tint="#FF1744"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PRIME"
                        android:textColor="#FF1744"
                        android:textSize="9sp"
                        android:fontFamily="sans-serif-black"
                        android:background="@drawable/bg_prime_badge"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Say: 'Call my close friend' or 'Message my love'"
                    android:textColor="#666"
                    android:textSize="11sp"
                    android:layout_marginBottom="14dp" />

                <EditText
                    android:id="@+id/primeNameInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Contact Name (e.g. Priya)"
                    android:textColor="#FFF"
                    android:textColorHint="#555"
                    android:background="@drawable/bg_input_field"
                    android:padding="12dp"
                    android:textSize="14sp"
                    android:layout_marginBottom="10dp" />

                <EditText
                    android:id="@+id/primeNumberInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Phone Number (+91XXXXXXXXXX)"
                    android:textColor="#FFF"
                    android:textColorHint="#555"
                    android:background="@drawable/bg_input_field"
                    android:padding="12dp"
                    android:inputType="phone"
                    android:textSize="14sp"
                    android:layout_marginBottom="12dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Personality Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#111"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💖 Personality Mode"
                    android:textColor="#FF6D6D"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="14dp" />

                <RadioGroup
                    android:id="@+id/personalityGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/gfRadio"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="💖 GF Mode — Caring, Hinglish, Emotional"
                        android:textColor="#CCC"
                        android:textSize="13sp"
                        android:buttonTint="#FF1744" />

                    <RadioButton
                        android:id="@+id/proRadio"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="💼 Professional Mode — Formal, English"
                        android:textColor="#CCC"
                        android:textSize="13sp"
                        android:buttonTint="#FF1744" />

                    <RadioButton
                        android:id="@+id/assistantRadio"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="🤖 Assistant Mode — Balanced, Friendly"
                        android:textColor="#CCC"
                        android:textSize="13sp"
                        android:buttonTint="#FF1744" />
                </RadioGroup>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Permissions Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#111"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🛡️ Advanced Permissions"
                    android:textColor="#FF6D6D"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="14dp" />

                <LinearLayout
                    android:id="@+id/deviceAdminCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="8dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_battery"
                        android:tint="#FF1744" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Device Administrator"
                            android:textColor="#EEE"
                            android:textSize="13sp" />
                        <TextView
                            android:id="@+id/adminStatusText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Not Active"
                            android:textColor="#888"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#222"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:id="@+id/accessibilityCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="8dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_settings"
                        android:tint="#FF1744" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Accessibility Service"
                            android:textColor="#EEE"
                            android:textSize="13sp" />
                        <TextView
                            android:id="@+id/accessibilityStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Checking..."
                            android:textColor="#888"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Permissions Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/permissionsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#111"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🛠️ Permissions"
                    android:textColor="#FF6D6D"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="14dp" />

                <Button
                    android:id="@+id/grantPermissionsBtn"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Grant Permissions"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#FF1744"
                    android:textAllCaps="false"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/permissionsStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Permissions status will appear here."
                    android:textColor="#888"
                    android:textSize="12sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Default Assistant Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#111"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🤖 Default Assistant"
                    android:textColor="#FF6D6D"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="14dp" />

                <Button
                    android:id="@+id/setDefaultAssistantBtn"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Set Default Assistant"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#FF1744"
                    android:textAllCaps="false" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Call Announce Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/callAnnounceCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="0dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#1A1A2E"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Title Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📢 Call Announce"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <!-- Main Toggle Switch -->
                    <Switch
                        android:id="@+id/callAnnounceSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumbTint="#FF6B9D"
                        android:trackTint="#3D1A3D"/>

                </LinearLayout>

                <!-- Description -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Call aane pe MYRA caller ka naam bolta hai"
                    android:textColor="#888888"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp"/>

                <!-- Status Text - dynamically updated from code -->
                <TextView
                    android:id="@+id/callAnnounceStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📢 Call aane pe MYRA naam bolegi"
                    android:textColor="#00E676"
                    android:textSize="12sp"
                    android:layout_marginTop="6dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Security & Privacy Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#111"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔐 Security &amp; Privacy"
                    android:textColor="#FF6D6D"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="14dp" />

                <LinearLayout
                    android:id="@+id/securitySettingsCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="8dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_settings"
                        android:tint="#00E676" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="App Lock &amp; Security"
                            android:textColor="#EEE"
                            android:textSize="13sp" />
                        <TextView
                            android:id="@+id/securityStatusText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PIN, Pattern, Voice Lock"
                            android:textColor="#888"
                            android:textSize="11sp" />
                    </LinearLayout>
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_settings"
                        android:tint="#444"
                        android:rotation="270" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Save Button -->
        <Button
            android:id="@+id/saveBtn"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="SAVE SETTINGS"
            android:textColor="#FFF"
            android:textSize="15sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.1"
            android:background="@drawable/bg_save_button"
            android:layout_marginBottom="32dp" />

    </LinearLayout>
</ScrollView>
