<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/jarvis_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingTop="48dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙️ SETTINGS"
            android:textColor="@color/jarvis_accent"
            android:textSize="22sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.3"
            android:layout_marginBottom="24dp" />

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- 1. GEMINI API KEY -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/jarvis_card"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔑 GEMINI API KEY"
                    android:textColor="@color/jarvis_accent"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Google AI — free at aistudio.google.com"
                    android:textColor="@color/jarvis_text_secondary"
                    android:textSize="11sp"
                    android:layout_marginBottom="12dp"/>

                <EditText
                    android:id="@+id/apiKeyInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="AIzaSy..."
                    android:textColor="@color/jarvis_text_primary"
                    android:textColorHint="#555"
                    android:background="@drawable/bg_input_dark"
                    android:padding="12dp"
                    android:inputType="textPassword"
                    android:fontFamily="monospace"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅ Required for AI features"
                    android:textColor="#4CAF50"
                    android:textSize="11sp"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- 2. ELEVENLABS API KEY (TTS) -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/jarvis_card"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🗣️ ELEVENLABS API KEY (TTS)"
                    android:textColor="#7C4DFF"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Optional — for premium voice output"
                    android:textColor="@color/jarvis_text_secondary"
                    android:textSize="11sp"
                    android:layout_marginBottom="12dp"/>

                <EditText
                    android:id="@+id/ttsApiKeyInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="ElevenLabs API Key..."
                    android:textColor="@color/jarvis_text_primary"
                    android:textColorHint="#555"
                    android:background="@drawable/bg_input_dark"
                    android:padding="12dp"
                    android:inputType="textPassword"
                    android:fontFamily="monospace"
                    android:textSize="13sp" />

                <!-- Voice Engine Selection -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Voice Engine:"
                    android:textColor="@color/jarvis_text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="8dp"/>

                <RadioGroup
                    android:id="@+id/voiceTypeGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/radioSystem"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="System TTS"
                        android:textColor="@color/jarvis_text_primary"
                        android:textSize="12sp"
                        android:buttonTint="@color/jarvis_accent" />

                    <RadioButton
                        android:id="@+id/radioEleven"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="ElevenLabs"
                        android:textColor="@color/jarvis_text_primary"
                        android:textSize="12sp"
                        android:buttonTint="#7C4DFF" />
                </RadioGroup>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Live Voice Mode"
                        android:textColor="@color/jarvis_text_primary"
                        android:textSize="13sp" />

                    <Switch
                        android:id="@+id/liveModeSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumbTint="@color/jarvis_accent"
                        android:trackTint="#444" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- 3. LANGUAGE -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/jarvis_card"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌐 LANGUAGE"
                    android:textColor="@color/jarvis_accent"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Choose your preferred language"
                    android:textColor="@color/jarvis_text_secondary"
                    android:textSize="11sp"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/languageBtn"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="🇧🇩 Banglish ▾"
                    android:textColor="@color/jarvis_text_primary"
                    android:background="@drawable/bg_input_dark"
                    android:gravity="start|center_vertical"
                    android:paddingStart="12dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- 4. YOUR NAME -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/jarvis_card"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👤 YOUR NAME"
                    android:textColor="@color/jarvis_accent"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Maya will call you this name"
                    android:textColor="@color/jarvis_text_secondary"
                    android:textSize="11sp"
                    android:layout_marginBottom="12dp"/>

                <EditText
                    android:id="@+id/userNameInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Sir"
                    android:textColor="@color/jarvis_text_primary"
                    android:textColorHint="#555"
                    android:background="@drawable/bg_input_dark"
                    android:padding="12dp"
                    android:textSize="14sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- 5. PRIME CONTACT -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/jarvis_card"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="⭐ PRIME CONTACT"
                        android:textColor="#FF1744"
                        android:textSize="14sp"
                        android:fontFamily="monospace" />

                    <ImageButton
                        android:id="@+id/pickContactBtn"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_contact_list"
                        android:tint="#FF1744"
                        android:contentDescription="Pick Contact" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Say: 'Call my close friend' or 'Message my love'"
                    android:textColor="@color/jarvis_text_secondary"
                    android:textSize="11sp"
                    android:layout_marginBottom="12dp"/>

                <EditText
                    android:id="@+id/primeNameInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Contact Name (e.g. Priya)"
                    android:textColor="@color/jarvis_text_primary"
                    android:textColorHint="#555"
                    android:background="@drawable/bg_input_dark"
                    android:padding="12dp"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/primeNumberInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Phone Number (+91XXXXXXXXXX)"
                    android:textColor="@color/jarvis_text_primary"
                    android:textColorHint="#555"
                    android:background="@drawable/bg_input_dark"
                    android:padding="12dp"
                    android:inputType="phone"
                    android:textSize="14sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- 6. PERMISSIONS -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/jarvis_card"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🛡️ PERMISSIONS"
                    android:textColor="@color/jarvis_accent"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/permissionsStatusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Checking permissions..."
                    android:textColor="@color/jarvis_text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/grantPermissionsBtn"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="🔓 Grant All Permissions"
                    android:textColor="@color/jarvis_text_primary"
                    android:background="@drawable/bg_input_dark"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:id="@+id/accessibilityCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="8dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Accessibility Service"
                        android:textColor="@color/jarvis_text_primary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/accessibilityStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Checking..."
                        android:textColor="@color/jarvis_text_secondary"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/deviceAdminCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="8dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Device Administrator"
                        android:textColor="@color/jarvis_text_primary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/adminStatusText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Checking..."
                        android:textColor="@color/jarvis_text_secondary"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- 7. FEATURES -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/jarvis_card"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎯 FEATURES"
                    android:textColor="@color/jarvis_accent"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="12dp"/>

                <!-- Screen Vision -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="👁️ Screen Vision (OCR)"
                        android:textColor="@color/jarvis_text_primary"
                        android:textSize="13sp" />

                    <Switch
                        android:id="@+id/screenVisionSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumbTint="@color/jarvis_accent"
                        android:trackTint="#444" />
                </LinearLayout>

                <TextView
                    android:id="@+id/screenVisionStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="❌ Screen Vision বন্ধ আছে"
                    android:textColor="@color/jarvis_text_secondary"
                    android:textSize="11sp"
                    android:layout_marginBottom="8dp"/>

                <!-- Call Announce -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📢 Call Announce"
                        android:textColor="@color/jarvis_text_primary"
                        android:textSize="13sp" />

                    <Switch
                        android:id="@+id/callAnnounceSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumbTint="@color/jarvis_accent"
                        android:trackTint="#444" />
                </LinearLayout>

                <TextView
                    android:id="@+id/callAnnounceStatusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📢 Call aane pe MAYA naam bolegi"
                    android:textColor="@color/jarvis_text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- 8. SAVE BUTTON -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Button
            android:id="@+id/saveBtn"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="💾 SAVE SETTINGS"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:fontFamily="monospace"
            android:background="@drawable/bg_save_button"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="32dp"/>

    </LinearLayout>
</ScrollView>
