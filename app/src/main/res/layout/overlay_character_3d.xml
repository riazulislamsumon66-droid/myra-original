<?xml version="1.0" encoding="utf-8"?>
<!--
    overlay_character_3d.xml
    Floating 3D character overlay — always above all other apps.
    Place in: app/src/main/res/layout/
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="160dp"
    android:layout_height="200dp"
    android:background="@android:color/transparent">

    <!-- 3D Character Canvas View -->
    <com.maya.assistant.ui.character.CharacterOverlayView
        android:id="@+id/characterOverlayView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Glow ring behind character (optional) -->
    <View
        android:id="@+id/characterGlow"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_maya_dot"
        android:alpha="0.3" />

</FrameLayout>
