<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Jarvis Dark Theme -->
    <style name="Theme.Maya" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">#00BCD4</item>
        <item name="colorPrimaryDark">#0097A7</item>
        <item name="colorAccent">#00E5FF</item>
        <item name="android:windowBackground">@color/jarvis_bg</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/jarvis_bg</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>

    <style name="Theme.Maya.Transparent" parent="Theme.MaterialComponents.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Jarvis Colors -->
    <color name="jarvis_bg">#0A0E27</color>
    <color name="jarvis_surface">#111633</color>
    <color name="jarvis_accent">#00E5FF</color>
    <color name="jarvis_accent_secondary">#7C4DFF</color>
    <color name="jarvis_text_primary">#E0E0E0</color>
    <color name="jarvis_text_secondary">#9E9E9E</color>
    <color name="jarvis_listening">#00E5FF</color>
    <color name="jarvis_thinking">#7C4DFF</color>
    <color name="jarvis_speaking">#FF1744</color>
    <color name="jarvis_idle">#1A237E</color>
    <color name="jarvis_card">#1A1F3D</color>
    <color name="jarvis_divider">#283055</color>
</resources>
